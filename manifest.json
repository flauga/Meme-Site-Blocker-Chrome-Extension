{
  "manifest_version": 3,
  "name": "MemeLord Site Blocker",
  "description": "Block distracting websites and get roasted by an AI-generated meme every time you try to visit one.",
  "version": "2.0",
  "permissions": ["storage"],
  "host_permissions": ["https://www.memelord.com/*"],
  "icons": {
    "16": "/images/icon16.png",
    "48": "/images/icon48.png",
    "128": "/images/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "/images/icon16.png",
      "48": "/images/icon48.png",
      "128": "/images/icon128.png"
    },
    "default_title": "MemeLord Site Blocker",
    "default_popup": "./popup/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["contentScript.js"]
  }]
}
